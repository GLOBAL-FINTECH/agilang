# Required: keep this secret on the server only.
SUNO_API_KEY=replace_with_your_sunoapi_key

# SunoAPI-compatible endpoints used by this example.
SUNO_API_BASE=https://api.sunoapi.org
SUNO_UPLOAD_BASE=https://sunoapiorg.redpandaai.co

# Public HTTPS base URL for callbacks, for example from your deployed domain or ngrok.
# Leave empty during local polling-only tests.
PUBLIC_CALLBACK_BASE_URL=

# CORS origins allowed to call this backend. Use comma-separated origins in production.
CORS_ALLOW_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Local server settings.
APP_HOST=127.0.0.1
APP_PORT=8000
