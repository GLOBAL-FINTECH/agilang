# Train and use a linear regression model

fn main() -> i32:
    # Prepare a simple dataset: y = 2x + 3
    let data = [
        [0.0],
        [1.0],
        [2.0],
        [3.0],
        [4.0],
    ]
    let targets = [3.0, 5.0, 7.0, 9.0, 11.0]
    let model = train_linear_regression(data, targets)
    # Make predictions on new points
    let preds = predict(model, [[5.0], [6.5]])
    print("Predictions for x=5 and x=6.5:", preds)
    return 0