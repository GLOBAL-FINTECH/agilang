fn main() -> i32:
    let code = "0x602a5f5260205ff3"
    let result = evm_execute(code)
    print("evm ok", result["ok"])
    print("gas used", result["gas_used"])
    print("output", result["output"])
    let decoded = evm_abi_decode(["uint256"], result["output"])
    print("decoded", decoded[0])
    let storage_result = evm_simulate_call("0x602a5f555f5400")
    print("storage slot zero", storage_result["storage"]["0"])
    return 0
